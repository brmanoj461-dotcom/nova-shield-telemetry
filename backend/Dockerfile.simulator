# Use an official, lightweight Python runtime base image
FROM python:3.11-slim

# Set the working directory inside the container
WORKDIR /app

# Directly install the requests library needed for sending HTTP payloads
RUN pip install --no-cache-dir requests

# Copy the complete simulator loop script into the container
COPY simulator.py .

# Execute the telemetry data stream on container startup
CMD ["python", "simulator.py"]